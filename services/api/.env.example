# Copy this file to api/.env and fill in your Supabase credentials.
# Use the SERVICE ROLE key (bypasses RLS to read all brackets).
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Optional — enables AI narrative generation after each sim run
# Primary OpenAI path
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5
# Optional override: openai | anthropic
LLM_PROVIDER=openai

# Legacy Anthropic fallback
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
