{
  "name": "sports-closet",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:tournament": "pnpm --filter tournament-tracker dev",
    "dev:draft": "pnpm --filter on-the-clock dev",
    "dev:nba:v1": "pnpm --filter nba-playoffs-v1 dev",
    "dev:nba:v2": "pnpm --filter nba-playoffs-v2 dev",
    "build": "turbo run build",
    "build:tournament": "pnpm --filter tournament-tracker build",
    "build:draft": "pnpm --filter on-the-clock build",
    "build:nba:v1": "pnpm --filter nba-playoffs-v1 build",
    "build:nba:v2": "pnpm --filter nba-playoffs-v2 build",
    "seed:nba:probabilities": "python3 services/api/seed_nba_probabilities.py",
    "lint": "turbo run lint",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > packages/shared/src/types/database.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.0"
}
